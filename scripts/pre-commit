#!/bin/bash
# Pre-commit hook for LuminaBridge
# Runs formatting and linting checks before allowing commits
#
# LuminaBridge 预提交钩子
# 在允许提交之前运行格式化和 lint 检查

set -e

echo "🌉 Running pre-commit checks for LuminaBridge..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any checks fail
FAILED=0

# Function to print status
print_status() {
    if [ $1 -eq 0 ]; then
        echo -e "${GREEN}✓${NC} $2"
    else
        echo -e "${RED}✗${NC} $2"
        FAILED=1
    fi
}

# Check if Rust is installed
if ! command -v cargo &> /dev/null; then
    echo -e "${RED}Error: Rust/Cargo is not installed${NC}"
    echo "Please install Rust from https://rustup.rs/"
    exit 1
fi

echo "Running checks..."
echo ""

# 1. Format check
echo -e "${YELLOW}Checking code formatting...${NC}"
if cargo fmt -- --check &> /dev/null; then
    print_status 0 "Code formatting check passed"
else
    print_status 1 "Code formatting check failed"
    echo "  Run 'cargo fmt' to fix formatting issues"
fi

# 2. Clippy lint
echo -e "${YELLOW}Running Clippy linter...${NC}"
if cargo clippy --all-targets --all-features -- -D warnings &> /dev/null; then
    print_status 0 "Clippy lint passed"
else
    print_status 1 "Clippy lint failed"
    echo "  Run 'cargo clippy --fix' to fix linting issues"
fi

# 3. Build check
echo -e "${YELLOW}Building project...${NC}"
if cargo build --all-targets &> /dev/null; then
    print_status 0 "Build check passed"
else
    print_status 1 "Build check failed"
fi

# 4. Test check (optional, can be slow)
echo -e "${YELLOW}Running tests (skip with SKIP_TESTS=1)...${NC}"
if [ "${SKIP_TESTS:-0}" = "1" ]; then
    echo "  Skipping tests (SKIP_TESTS=1)"
else
    if cargo test --lib &> /dev/null; then
        print_status 0 "Tests passed"
    else
        print_status 1 "Tests failed"
    fi
fi

echo ""

# Final status
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
    exit 0
else
    echo -e "${RED}❌ Some pre-commit checks failed. Please fix the issues above.${NC}"
    echo ""
    echo "You can skip this hook with --no-verify (not recommended)"
    exit 1
fi
