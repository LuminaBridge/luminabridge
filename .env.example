# LuminaBridge Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Server Configuration
# =============================================================================
LUMINABRIDGE__SERVER__HOST=127.0.0.1
LUMINABRIDGE__SERVER__PORT=3000
LUMINABRIDGE__SERVER__WORKERS=2
LUMINABRIDGE__SERVER__TIMEOUT_SECS=30
LUMINABRIDGE__SERVER__MAX_CONNECTIONS=100

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
# Format: postgres://username:password@host:port/database
LUMINABRIDGE__DATABASE__URL=postgres://luminabridge:your_password@localhost:5432/luminabridge_dev
LUMINABRIDGE__DATABASE__MAX_CONNECTIONS=10
LUMINABRIDGE__DATABASE__MIN_CONNECTIONS=2
LUMINABRIDGE__DATABASE__TIMEOUT_SECS=30

# =============================================================================
# OAuth Configuration
# =============================================================================
# JWT Secret (must be at least 32 characters for security)
# Generate with: openssl rand -base64 32
LUMINABRIDGE__OAUTH__JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# Token expiration in seconds (default: 86400 = 24 hours)
LUMINABRIDGE__OAUTH__TOKEN_EXPIRATION_SECS=86400

# GitHub OAuth (optional)
# Register at: https://github.com/settings/developers
LUMINABRIDGE__OAUTH__GITHUB__CLIENT_ID=your_github_client_id
LUMINABRIDGE__OAUTH__GITHUB__CLIENT_SECRET=your_github_client_secret
LUMINABRIDGE__OAUTH__GITHUB__REDIRECT_URL=http://localhost:3000/auth/github/callback
LUMINABRIDGE__OAUTH__GITHUB__SCOPES=read:user,user:email

# Discord OAuth (optional)
# Register at: https://discord.com/developers/applications
LUMINABRIDGE__OAUTH__DISCORD__CLIENT_ID=your_discord_client_id
LUMINABRIDGE__OAUTH__DISCORD__CLIENT_SECRET=your_discord_client_secret
LUMINABRIDGE__OAUTH__DISCORD__REDIRECT_URL=http://localhost:3000/auth/discord/callback
LUMINABRIDGE__OAUTH__DISCORD__SCOPES=identify,email

# =============================================================================
# Cache Configuration (Redis) - Optional
# =============================================================================
# Format: redis://host:port
LUMINABRIDGE__CACHE__URL=redis://localhost:6379
LUMINABRIDGE__CACHE__MAX_CONNECTIONS=10

# =============================================================================
# Logging Configuration
# =============================================================================
# Levels: trace, debug, info, warn, error
LUMINABRIDGE__LOGGING__LEVEL=debug
LUMINABRIDGE__LOGGING__FORMAT=pretty
# LUMINABRIDGE__LOGGING__FILE=logs/luminabridge.log

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
LUMINABRIDGE__RATE_LIMIT__ENABLED=false
LUMINABRIDGE__RATE_LIMIT__REQUESTS_PER_SEC=100
LUMINABRIDGE__RATE_LIMIT__BURST_SIZE=50

# =============================================================================
# Retry Configuration
# =============================================================================
# Maximum number of retry attempts for failed requests
LUMINABRIDGE__RETRY__MAX_RETRIES=3

# Base delay in milliseconds for exponential backoff
LUMINABRIDGE__RETRY__BASE_DELAY_MS=1000

# Maximum delay in milliseconds between retries
LUMINABRIDGE__RETRY__MAX_DELAY_MS=30000

# =============================================================================
# Pricing Configuration
# =============================================================================
# Default pricing mode: builtin (use built-in pricing) or custom (use database)
LUMINABRIDGE__PRICING__MODE=builtin

# Custom pricing file path (only used if MODE=custom)
# LUMINABRIDGE__PRICING__CUSTOM_FILE=config/pricing.json

# =============================================================================
# Alert Configuration
# =============================================================================
# Enable automatic alert generation
LUMINABRIDGE__ALERTS__ENABLED=true

# Alert check interval in seconds
LUMINABRIDGE__ALERTS__CHECK_INTERVAL_SECS=300

# Error rate threshold for channel alerts (percentage)
LUMINABRIDGE__ALERTS__ERROR_RATE_THRESHOLD=10.0

# Latency threshold for channel alerts (milliseconds)
LUMINABRIDGE__ALERTS__LATENCY_THRESHOLD_MS=5000

# Balance threshold for channel alerts
LUMINABRIDGE__ALERTS__BALANCE_THRESHOLD=10.0

# Quota usage threshold for token alerts (percentage)
LUMINABRIDGE__ALERTS__QUOTA_THRESHOLD=80.0

# =============================================================================
# Alert Notification Channels
# =============================================================================
# Email Notifications (SMTP)
LUMINABRIDGE__ALERTS__EMAIL_ENABLED=false
LUMINABRIDGE__ALERTS__EMAIL_SMTP_HOST=smtp.example.com
LUMINABRIDGE__ALERTS__EMAIL_SMTP_PORT=587
LUMINABRIDGE__ALERTS__EMAIL_USERNAME=alerts@example.com
LUMINABRIDGE__ALERTS__EMAIL_PASSWORD=your_smtp_password
LUMINABRIDGE__ALERTS__EMAIL_RECIPIENTS=admin@example.com,team@example.com

# Webhook Notifications (Generic/Slack)
LUMINABRIDGE__ALERTS__WEBHOOK_ENABLED=false
LUMINABRIDGE__ALERTS__WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord Notifications
LUMINABRIDGE__ALERTS__DISCORD_ENABLED=false
LUMINABRIDGE__ALERTS__DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL
