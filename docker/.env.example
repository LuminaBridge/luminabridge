# LuminaBridge Docker Environment Configuration
# Copy this file to .env and customize for your deployment
# cp .env.example .env

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
POSTGRES_USER=luminabridge
POSTGRES_PASSWORD=change_this_secure_password_123
POSTGRES_DB=luminabridge_dev
POSTGRES_PORT=5432

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_PORT=6379

# =============================================================================
# Backend Configuration
# =============================================================================
BACKEND_PORT=3000
BACKEND_WORKERS=2
LOG_LEVEL=info

# JWT Secret - MUST be changed in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-characters

# =============================================================================
# Frontend Configuration
# =============================================================================
FRONTEND_PORT=80

# =============================================================================
# pgAdmin Configuration (Optional)
# =============================================================================
PGADMIN_PORT=8080
PGADMIN_EMAIL=admin@luminabridge.local
PGADMIN_PASSWORD=admin

# =============================================================================
# OAuth Configuration (Optional)
# =============================================================================
# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:3000/auth/github/callback

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URL=http://localhost:3000/auth/discord/callback

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_ENABLED=false
