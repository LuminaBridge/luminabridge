# LuminaBridge .dockerignore
# Exclude files and directories from Docker build context

# =============================================================================
# Build artifacts
# =============================================================================
target/
**/target/
**/node_modules/
dist/
**/dist/
build/
**/build/

# =============================================================================
# Git
# =============================================================================
.git/
.gitignore
.gitattributes

# =============================================================================
# Documentation
# =============================================================================
*.md
!README.md
docs/
**/*.md

# =============================================================================
# Tests
# =============================================================================
tests/
**/tests/
**/*.test.*
**/*.spec.*
coverage/
**/coverage/

# =============================================================================
# IDE and Editor files
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Local configuration
# =============================================================================
.env
.env.local
.env.*.local
*.local

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Docker (avoid recursive copies)
# =============================================================================
docker-compose*.yml
Dockerfile*
.docker/
docker/

# =============================================================================
# Scripts (not needed in container)
# =============================================================================
scripts/
**/scripts/

# =============================================================================
# Mock servers and test data
# =============================================================================
mock-server/
**/mock*/
testdata/
**/testdata/

# =============================================================================
# CI/CD
# =============================================================================
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# =============================================================================
# Misc
# =============================================================================
*.tmp
*.temp
.cache/
.parcel-cache/
